/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model fall_events {
  id                Int          @id @default(autoincrement())
  uuid              String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  device_id         Int
  detected_at       DateTime     @db.Timestamptz(6)
  confidence        Decimal      @db.Decimal(4, 3)
  model_version     String?      @db.VarChar(20)
  latitude          Decimal?     @db.Decimal(10, 8)
  longitude         Decimal?     @db.Decimal(11, 8)
  location_accuracy Float?       @db.Real
  address           String?
  user_notified_at  DateTime?    @db.Timestamptz(6)
  user_responded_at DateTime?    @db.Timestamptz(6)
  user_cancelled    Boolean?     @default(false)
  cancel_reason     String?      @db.VarChar(255)
  sos_triggered     Boolean?     @default(false)
  sos_triggered_at  DateTime?    @db.Timestamptz(6)
  features          Json?
  created_at        DateTime?    @default(now()) @db.Timestamptz(6)
  alerts            alerts[]
  devices           devices      @relation(fields: [device_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sos_events        sos_events[]

  @@index([confidence(sort: Desc)], map: "idx_fall_events_confidence")
  @@index([device_id, detected_at(sort: Desc)], map: "idx_fall_events_device")
}

