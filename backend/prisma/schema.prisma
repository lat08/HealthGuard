generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model alerts {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         Int
  device_id       Int?
  alert_type      String       @db.VarChar(50)
  title           String       @db.VarChar(255)
  message         String?
  severity        String?      @default("medium") @db.VarChar(20)
  fall_event_id   Int?
  sos_event_id    Int?
  data            Json?
  sent_at         DateTime?    @db.Timestamptz(6)
  delivered_at    DateTime?    @db.Timestamptz(6)
  read_at         DateTime?    @db.Timestamptz(6)
  acknowledged_at DateTime?    @db.Timestamptz(6)
  sent_via        String[]     @default(["push"])
  created_at      DateTime?    @default(now()) @db.Timestamptz(6)
  expires_at      DateTime?    @db.Timestamptz(6)
  devices         devices?     @relation(fields: [device_id], references: [id], onUpdate: NoAction)
  fall_events     fall_events? @relation(fields: [fall_event_id], references: [id], onUpdate: NoAction)
  sos_events      sos_events?  @relation(fields: [sos_event_id], references: [id], onUpdate: NoAction)
  users           users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([device_id, created_at(sort: Desc)], map: "idx_alerts_device")
  @@index([alert_type, created_at(sort: Desc)], map: "idx_alerts_type")
  @@index([user_id, created_at(sort: Desc)], map: "idx_alerts_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model audit_logs {
  id            BigInt   @default(autoincrement())
  time          DateTime @default(now()) @db.Timestamptz(6)
  user_id       Int?
  device_id     Int?
  action        String   @db.VarChar(100)
  resource_type String?  @db.VarChar(50)
  resource_id   Int?
  details       Json?
  ip_address    String?  @db.Inet
  user_agent    String?
  status        String?  @db.VarChar(20)
  error_message String?
  devices       devices? @relation(fields: [device_id], references: [id], onUpdate: NoAction)
  users         users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@id([id, time])
  @@index([time(sort: Desc)])
  @@index([action, time(sort: Desc)], map: "idx_audit_logs_action")
  @@index([resource_type, resource_id, time(sort: Desc)], map: "idx_audit_logs_resource")
  @@index([status, time(sort: Desc)], map: "idx_audit_logs_status")
  @@index([user_id, time(sort: Desc)], map: "idx_audit_logs_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model devices {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          Int
  device_name      String?       @db.VarChar(100)
  device_type      String?       @default("smartwatch") @db.VarChar(50)
  model            String?       @db.VarChar(100)
  firmware_version String?       @db.VarChar(20)
  mac_address      String?       @db.VarChar(17)
  serial_number    String?       @db.VarChar(100)
  is_active        Boolean?      @default(true)
  battery_level    Int?          @db.SmallInt
  signal_strength  Int?          @db.SmallInt
  last_seen_at     DateTime?     @db.Timestamptz(6)
  last_sync_at     DateTime?     @db.Timestamptz(6)
  mqtt_client_id   String?       @db.VarChar(100)
  calibration_data Json?
  registered_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?     @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?     @db.Timestamptz(6)
  alerts           alerts[]
  audit_logs       audit_logs[]
  users            users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fall_events      fall_events[]
  motion_data      motion_data[]
  risk_scores      risk_scores[]
  sos_events       sos_events[]
  vitals           vitals[]

  @@index([last_seen_at(sort: Desc)], map: "idx_devices_last_seen")
  @@index([mqtt_client_id], map: "idx_devices_mqtt_client")
  @@index([user_id], map: "idx_devices_user")
  @@index([uuid], map: "idx_devices_uuid")
}

